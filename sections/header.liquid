<header class="jv-header" style="
  background-color: {{ section.settings.background_color }};
  color: {{ section.settings.text_color }};
  --logo-size-desktop: {{ section.settings.logo_size_desktop }}px;
  --logo-size-mobile: {{ section.settings.logo_size_mobile }}px;
  --slogan-size-desktop: {{ section.settings.slogan_size_desktop }}px;
  --slogan-size-mobile: {{ section.settings.slogan_size_mobile }}px;
  --icon-size-desktop: {{ section.settings.icon_size_desktop }}px;
  --icon-size-mobile: {{ section.settings.icon_size_mobile }}px;
">
  <div class="jv-header__container">
    <!-- Logo + slogan (desktop only) -->
    <div class="jv-header__brand">
      <a href="{{ routes.root_url }}" class="jv-header__logo">
        {% if section.settings.logo %}
          <img src="{{ section.settings.logo | img_url: '200x' }}" alt="{{ shop.name }}">
        {% else %}
          <span class="jv-header__text-logo">{{ shop.name }}</span>
        {% endif %}
      </a>
      {% if section.settings.slogan != blank %}
        <div class="jv-header__slogan jv-header__slogan--desktop"style="padding-top:2px;">
          <p >{{ section.settings.slogan }}</p>
        </div>
      {% endif %}
    </div>

    <!-- MENU trigger (mobile) + nav + ícones -->
   <div class="jv-header__actions">
    <button type="button" class="jv-header__mobile-menu-trigger" style="color:#000;"><b>MENU</b></button>

      <!-- Overlay do Drawer -->
      <div class="jv-drawer-overlay"></div>

      <!-- Drawer -->
      <div class="jv-drawer" aria-hidden="true" style="width:100%;">
        <!-- Cabeçalho do Drawer: logo + botão Fechar -->
        <div class="jv-drawer__head">
          <a href="{{ routes.root_url }}" class="jv-drawer__logo">
            {% if section.settings.logo %}
              <img
                src="{{ section.settings.logo | img_url: '200x' }}"
                alt="{{ shop.name }}"
                style="height: var(--logo-size-mobile);width:auto!important;"
              >
            {% endif %}
          </a>
          <button
            class="jv-drawer__close"
            aria-label="Fechar menu"
            style="background:none;border:none;padding:0;"
          >
            <svg
              class="jv-drawer__close-icon"
              style="transition: transform .3s ease"
              fill="#000000"
              viewBox="0 0 64 64"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M30.034,29.948l0,-21.983l3.741,0l0,21.983l22.203,0l0,3.741l-22.203,0l0,22.203l-3.741,0l0,-22.203l-22.008,0l0,-3.741l22.008,0Z"
              />
            </svg>
          </button>
        </div>

        <!-- Abas de topo -->
        <ul class="jv-drawer__tabs" role="tablist" style="display:flex;gap:14px;list-style:none;padding:0;">
          {% assign menu = linklists[section.settings.main_menu] %}
          {% for item in menu.links %}
            <li role="presentation">
              {% if item.links and item.links.size > 0 %}
                <button
                  type="button"
                  role="tab"
                  class="jv-drawer__tab{% if forloop.first %} active{% endif %}"
                  data-index="{{ forloop.index0 }}"
                  aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                >
                  <b>{{ item.title }}</b>
                </button>
              {% else %}
                <a
                  href="{{ item.url }}"
                  class="jv-drawer__tab jv-drawer__tab--link"
                >
                  <b>{{ item.title }}</b>
                </a>
              {% endif %}
            </li>
          {% endfor %}
        </ul>

        <!-- Painéis de submenu (pré‑renderizados) -->
        <div class="jv-drawer__panels">
          {% for item in menu.links %}
            <div
              class="jv-drawer__panel{% if forloop.first %} active{% endif %}"
              data-index="{{ forloop.index0 }}"
              role="tabpanel"
              style="margin-left:20px;"
            >
              {% for group in item.links %}
                <div class="jv-menu-group">

                              <h3 class="jv-menu-title"
                                                  style="
                      font-size: {{ section.settings.submenu_text_size }}px;
                      color: inherit;
                      margin-bottom:8px;
                    ">
              {% if group.url %}
                <a href="{{ group.url }}" class="jv-menu-title__link">
                  {{ group.title }}
                </a>
              {% else %}
                {{ group.title }}
              {% endif %}
            </h3>
                  {% if group.links and group.links.size > 0 %}
                    <ul
                      class="jv-menu-list"
                      style="list-style:none;margin:0;padding:0;"
                    >
                      {% for sub in group.links %}
                        <li style="margin:4px 0;">
                          <a
                            href="{{ sub.url }}"
                            style="
                              font-size: {{ section.settings.submenu_item_text_size }}px;
                              color: #7b7b7b;
                            "
                          >
                            {{ sub.title }}
                          </a>
                        </li>
                      {% endfor %}
                    </ul>
                  {% endif %}
                </div>
              {% endfor %}
            </div>
          {% endfor %}
        </div>
      </div>

<nav class="jv-header__nav">
  <ul class="jv-header__nav-list">
    {% assign menu = linklists[section.settings.main_menu] %}
    {% for link in menu.links %}
      <li class="jv-header__nav-item{% if link.links and link.links.size > 0 %} has-submenu{% endif %}">
        {% if link.links and link.links.size > 0 %}
          <a type="button" class="jv-header__nav-link" style="border:none;">
            <b>{{ link.title }}</b>
          </a>
        {% else %}
          <a href="{{ link.url }}" class="jv-header__nav-link">
            <b>{{ link.title }}</b>
          </a>
        {% endif %}
      </li>
    {% endfor %}

  </ul>
</nav>


