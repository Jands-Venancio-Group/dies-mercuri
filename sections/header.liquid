<script>
document.addEventListener('DOMContentLoaded', function() {
  // Seletores do toggle de idioma
  const localeToggle = document.querySelector('.jv-header__locale');
  if (!localeToggle) return;

  const img       = localeToggle.querySelector('img');
  const text      = localeToggle.querySelector('.jv-header__locale-text');
  const ptFlagSrc = img.src;
  const enFlagSrc = 'https://cdn.shopify.com/s/files/1/0889/4604/9310/files/EN.svg?v=1752851251';

  // Determina idioma inicial (storage ou URL)
  let locale = localStorage.getItem('locale') ||
               (window.location.pathname.startsWith('/en') ? 'en' : 'pt');

  function updateLocale(shouldRedirect) {
    if (locale === 'en') {
      img.src = enFlagSrc;
      img.alt = 'EN';
      text.textContent = 'EN';
      if (shouldRedirect && !window.location.pathname.startsWith('/en')) {
        // redireciona adicionando /en
        const rest = window.location.pathname + window.location.search + window.location.hash;
        window.location.href = '/en' + (rest === '/' ? '' : rest);
      }
    } else {
      img.src = ptFlagSrc;
      img.alt = 'PT';
      text.textContent = 'PT';
      if (shouldRedirect && window.location.pathname.startsWith('/en')) {
        // remove o /en
        const rest = window.location.pathname.replace(/^\/en/, '') + window.location.search + window.location.hash;
        window.location.href = rest || '/';
      }
    }
  }

  // Aplica no carregamento, redirecionando se necessário
  updateLocale(true);

  // Ao clicar na bandeira, alterna e persiste
  localeToggle.addEventListener('click', function(e) {
    e.preventDefault();
    locale = (locale === 'pt' ? 'en' : 'pt');
    localStorage.setItem('locale', locale);
    updateLocale(true);
  });
});
</script>

          
<script>

// Seleciona todas as tabs e painéis
const tabs   = document.querySelectorAll('.jv-drawer__tab');
const panels = document.querySelectorAll('.jv-drawer__panel');

tabs.forEach(tab => {
  tab.addEventListener('click', () => {
    const idx = tab.dataset.index;

    // 1) Atualiza abas
    tabs.forEach(t => {
      t.classList.toggle('active', t === tab);
      t.setAttribute('aria-selected', t === tab ? 'true' : 'false');
    });

    // 2) Atualiza painéis
    panels.forEach(panel => {
      panel.classList.toggle('active', panel.dataset.index === idx);
    });
  });
});

  
  
document.addEventListener('DOMContentLoaded', function(){
  const openBtn  = document.querySelector('.jv-header__mobile-menu-trigger');
  const drawer   = document.querySelector('.jv-drawer');
  const overlay  = document.querySelector('.jv-drawer-overlay');
  const closeBtn = document.querySelector('.jv-drawer__close');
  const tabs     = Array.from(document.querySelectorAll('.jv-drawer__tab'));
  const panel    = document.querySelector('.jv-drawer__content');
  const menuData = {{ linklists[section.settings.main_menu] | json }};

  function openDrawer(){
    drawer.classList.add('open');
    overlay.classList.add('open');
    drawer.setAttribute('aria-hidden','false');
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer(){
    drawer.classList.remove('open');
    overlay.classList.remove('open');
    drawer.setAttribute('aria-hidden','true');
    document.body.style.overflow = '';
  }

  openBtn.addEventListener('click', openDrawer);
  closeBtn.addEventListener('click', closeDrawer);
  overlay.addEventListener('click', closeDrawer);

  function showTab(i){
    tabs.forEach((t, idx) => {
      t.classList.toggle('active', idx === i);
      t.setAttribute('aria-selected', idx === i ? 'true' : 'false');
    });
    const items = menuData.links[i].links || [];
    let html = '';
    items.forEach(group => {
      html += `<div class="jv-menu-group">`;
      html += `<h3 class="jv-menu-title">${group.title}</h3>`;
      if (group.links && group.links.length) {
        html += '<ul class="jv-menu-list">';
        group.links.forEach(sub => {
          html += `<li><a href="${sub.url}">${sub.title}</a></li>`;
        });
        html += '</ul>';
      }
      html += `</div>`;
    });
    panel.innerHTML = html;
  }

  tabs.forEach((tab, i) => {
    tab.addEventListener('click', () => {
      const linkItem = menuData.links[i];
      const hasSub   = linkItem.links && linkItem.links.length > 0;
      if (!hasSub) {
        window.location.href = linkItem.url;
      } else {
        showTab(i);
      }
    });
  });

  // Exibe primeiro submenu se existir
  if (menuData.links[0].links && menuData.links[0].links.length > 0) {
    showTab(0);
  }
});

document.addEventListener('DOMContentLoaded', () => {
  const desktopOverlay = document.querySelector('.jv-drawer-desktop-overlay');
  const desktopDrawer  = document.querySelector('.jv-drawer-desktop');
  const desktopClose   = document.querySelector('.jv-drawer-desktop__close');
  const desktopTitle   = document.querySelector('.jv-drawer-desktop__title');
  const desktopContent = document.querySelector('.jv-drawer-desktop__content');

  // botões de abrir (só aqueles com submenu)
  document.querySelectorAll('.jv-header__nav-item.has-submenu .jv-header__nav-link')
    .forEach((btn, idx) => {
      btn.addEventListener('click', e => {
        e.preventDefault();
        const item = menuData.links[idx];
        // título
        desktopTitle.textContent = item.title;
        // conteúdo
        let html = '';
        (item.links || []).forEach(group => {
          html += `<div class="jv-menu-group">
                     <h3 class="jv-menu-title">${group.title}</h3>`;
          if (group.links) {
            html += `<ul class="jv-menu-list">`;
            group.links.forEach(sub => {
              html += `<li><a href="${sub.url}">${sub.title}</a></li>`;
            });
            html += `</ul>`;
          }
          html += `</div>`;
        });
        desktopContent.innerHTML = html;
        // abrir
        desktopDrawer.classList.add('open');
        desktopOverlay.classList.add('open');
        document.body.style.overflow = 'hidden';
      });
    });

  // fechar
  function closeDesktop() {
    desktopDrawer.classList.remove('open');
    desktopOverlay.classList.remove('open');
    document.body.style.overflow = '';
  }
  desktopClose.addEventListener('click', closeDesktop);
  desktopOverlay.addEventListener('click', closeDesktop);
});

  
</script>

