<script>
document.addEventListener('DOMContentLoaded', () => {
  const menuData       = {{ linklists[section.settings.main_menu] | json }};
  const overlay        = document.querySelector('.jv-drawer-desktop-overlay');
  const drawer         = document.querySelector('.jv-drawer-desktop');
  const closeBtn       = document.querySelector('.jv-drawer-desktop__close');
  const closeIcon      = closeBtn.querySelector('.jv-drawer-desktop__close-icon');
  const tabs           = Array.from(document.querySelectorAll('.jv-drawer-desktop__tab'));
  const panels         = Array.from(document.querySelectorAll('.jv-drawer-desktop__panel'));
  const navItems       = Array.from(document.querySelectorAll('.jv-header__nav-item.has-submenu'));

  function openDesktop(idx) {
    // 1) Marca o nav item ativo (borda inferior)
    navItems.forEach((li,i) => li.classList.toggle('active', i === idx));

    // 2) Atualiza abas e painéis do sidebar
    tabs.forEach((tab,i) => {
      const active = i === idx;
      tab.classList.toggle('active', active);
      tab.setAttribute('aria-selected', active);
    });
    panels.forEach(panel => {
      panel.classList.toggle('active', Number(panel.dataset.index) === idx);
    });

    // 3) Remove qualquer rotação extra do ícone
    closeIcon.classList.remove('rotated');

    // 4) Exibe o sidebar
    overlay.classList.add('open');
    drawer.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeDesktop() {
    // Esconde o sidebar
    drawer.classList.remove('open');
    overlay.classList.remove('open');
    document.body.style.overflow = '';

    // Rotaciona o ícone mais 45°
    closeIcon.classList.add('rotated');

    navItems.forEach(li => li.classList.remove('active'));
  }

// Ao invés de hover, abre o sidebar no click
navItems.forEach((li, idx) => {
  // pega o link/button dentro do li
  const trigger = li.querySelector('.jv-header__nav-link');
  if (!trigger) return;

  trigger.addEventListener('click', function(e) {
    e.preventDefault();
    openDesktop(idx);
  });
});

  closeBtn.addEventListener('click', closeDesktop);
  overlay.addEventListener('click', closeDesktop);

  const firstWithSub = menuData.links.findIndex(item =>
    Array.isArray(item.links) && item.links.length > 0
  );
  if (firstWithSub >= 0) openDesktop(firstWithSub);
});

</script>

          
