{%- comment -%}
  blocks/jv_slideshow.liquid
  Theme Block: Slideshow que aceita apenas blocos _slide
  + Paginação “barras” avançada conforme especificado
{%- endcomment -%}

{%- if block.blocks.size > 1 -%}
  {% capture controls -%}
    {% render 'slideshow-controls',
      style:               block.settings.slideshow_controls_style,
      autoplay:            block.settings.autoplay,
      item_count:          block.blocks.size,
      show_arrows:         false,
      arrows_on_media:     true,
      controls_on_media:   true,
      pagination_position: 'center',
      icon_style:          block.settings.icons_style
    %}
  {%- endcapture -%}
{%- endif -%}

{% capture slides %}
  {% for slide_block in block.blocks %}
    {% render slide_block %}
  {% endfor %}
{% endcapture %}

{% if block.blocks.size > 1 %}
  {% assign slideshow_class = '' %}
{% else %}
  {% assign slideshow_class = 'slideshow--single-media' %}
{% endif %}

{% if block.settings.icons_style != 'none' and block.blocks.size > 1 %}
  {% assign show_arrows = true %}
{% else %}
  {% assign show_arrows = false %}
{% endif %}

<div
  id="block-{{ block.id }}"
  class="spacing-style section section--{{ block.settings.section_width }} color-{{ block.settings.color_scheme }} disable-section-top-offset"
  style="{% render 'spacing-padding', settings: block.settings %}"
>
  {% render 'slideshow',
    class:           slideshow_class,
    controls:        controls,
    show_arrows:     show_arrows,
    icon_style:      block.settings.icons_style,
    autoplay:        block.settings.autoplay,
    autoplay_speed:  block.settings.autoplay_speed,
    slides:          slides,
    slide_count:     block.blocks.size,
    slide_size:      block.settings.slide_height
  %}
  
  {% if block.settings.slideshow_controls_style == 'bars' and block.settings.pagination_placement == 'below' %}
    <div class="jv-pagination-bars">
      {% for i in (1..block.blocks.size) %}
        <div class="bar"><div class="bar-fill"></div></div>
      {% endfor %}
    </div>
  {% endif %}
</div>

<style>
  /* Width responsivo do slideshow */
  @media screen and (max-width: 769px) {
    #block-{{ block.id }} > slideshow-component {
      width: {{ block.settings.width_mobile }}px !important;
    }
  }
  @media screen and (min-width: 770px) {
    #block-{{ block.id }} > slideshow-component {
      width: {{ block.settings.width_desktop }}px !important;
    }
  }

  /* Paginação “barras” */
  {% if block.settings.slideshow_controls_style == 'bars' %}
    #block-{{ block.id }} .jv-pagination-bars {
      display: flex;
      gap: 8px;
      {% if block.settings.pagination_placement == 'below' %}
        margin-top: {{ block.settings.pagination_bar_spacing }}px;
      {% endif %}
      max-width: {{ block.settings.pagination_bars_max_width }}px;
      margin-left: auto;
      margin-right: auto;
    }
    #block-{{ block.id }} .jv-pagination-bars .bar {
      flex: 1;
      height: 4px;
      background: {{ block.settings.pagination_bar_color }};
      overflow: hidden;
      position: relative;
    }
    #block-{{ block.id }} .jv-pagination-bars .bar-fill {
      width: 0;
      height: 100%;
      background: {{ block.settings.pagination_bar_fill_color }};
    }
    @keyframes fill-{{ block.id }} {
      from { width: 0% }
      to   { width: 100% }
    }
  {% endif %}
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const blockEl = document.getElementById('block-{{ block.id }}');
    const slideshow = blockEl.querySelector('slideshow-component');
    const fills = Array.from(blockEl.querySelectorAll('.jv-pagination-bars .bar-fill'));

    function activate(index) {
      fills.forEach((f,i) => {
        f.style.animation = 'none';
        f.style.width = '0';
        if(i === index && {{ block.settings.autoplay | json }}) {
          f.style.animation = `fill-{{ block.id }} {{ block.settings.autoplay_speed }}s linear forwards`;
        }
      });
    }

    // Inicial
    activate(0);

    // Ao trocar de página
    slideshow.addEventListener('page-changed', e => activate(e.detail.page));

    // Pausa ao hover
    blockEl.addEventListener('mouseover', () => {
      fills.forEach(f => f.style.animationPlayState = 'paused');
    });
    blockEl.addEventListener('mouseout', () => {
      fills.forEach(f => f.style.animationPlayState = 'running');
    });
  });
</script>

{% schema %}
{
  "name": "t:names.slideshow",
  "class": "container-background-image",
  "blocks": [{ "type": "_slide" }],
  "settings": [
    {
      "type": "select",
      "id": "icons_style",
      "label": "t:settings.navigation",
      "options": [
        { "value": "arrow",        "label": "t:options.arrows" },
        { "value": "chevron",      "label": "t:options.chevrons" },
        { "value": "arrows_large", "label": "t:options.large_arrows" },
        { "value": "chevron_large","label": "t:options.large_chevrons" },
        { "value": "none",         "label": "t:options.none" }
      ],
      "default": "arrows_large"
    },
    {
      "type": "select",
      "id": "slideshow_controls_style",
      "label": "t:settings.pagination",
      "options": [
        { "value": "dots",    "label": "t:options.dots" },
        { "value": "counter","label": "t:options.counter" },
        { "value": "bars",   "label": "Barras" }
      ],
      "default": "dots"
    },
    {
      "type": "color",
      "id": "pagination_bar_color",
      "label": "Cor da barra",
      "default": "#e0e0e0",
      "visible_if": "{{ block.settings.slideshow_controls_style == 'bars' }}"
    },
    {
      "type": "color",
      "id": "pagination_bar_fill_color",
      "label": "Cor do preenchimento",
      "default": "#000000",
      "visible_if": "{{ block.settings.slideshow_controls_style == 'bars' }}"
    },
    {
      "type": "select",
      "id": "pagination_placement",
      "label": "Posição da paginação",
      "options": [
        { "value": "overlay", "label": "Sobre a imagem" },
        { "value": "below",   "label": "Abaixo da imagem" }
      ],
      "default": "overlay",
      "visible_if": "{{ block.settings.slideshow_controls_style == 'bars' }}"
    },
    {
      "type": "range",
      "id": "pagination_bar_spacing",
      "label": "Espaçamento imagem-paginação",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ block.settings.slideshow_controls_style == 'bars' and block.settings.pagination_placement == 'below' }}"
    },
    {
      "type": "range",
      "id": "pagination_bars_max_width",
      "label": "Largura máxima da paginação",
      "min": 0,
      "max": 350,
      "step": 10,
      "unit": "px",
      "default": 350,
      "visible_if": "{{ block.settings.slideshow_controls_style == 'bars' }}"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "primary"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:settings.auto_rotate_slides",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "t:settings.speed",
      "min": 3,
      "max": 7,
      "step": 1,
      "unit": "s",
      "default": 4,
      "visible_if": "{{ block.settings.autoplay }}"
    },
    {
      "type": "header",
      "content": "t:content.size"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "full-width"
    },
    {
      "type": "select",
      "id": "slide_height",
      "label": "t:settings.height",
      "options": [
        { "value": "auto",   "label": "t:options.auto" },
        { "value": "small",  "label": "t:options.small" },
        { "value": "medium", "label": "t:options.medium" },
        { "value": "large",  "label": "t:options.large" }
      ],
      "default": "medium"
    },
    {
      "type": "range",
      "id": "width_mobile",
      "label": "Width mobile",
      "min": 100,
      "max": 330,
      "step": 5,
      "unit": "px",
      "default": 330
    },
    {
      "type": "range",
      "id": "width_desktop",
      "label": "Width desktop",
      "min": 100,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "default": 1000
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.slideshow",
      "category": "t:categories.storytelling",
      "blocks": [{ "type": "_slide"}]
    }
  ]
}
{% endschema %}
